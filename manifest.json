{
    "name": "Slopify",
    "version": "2.0",
    "description": "Fact-check highlighted text on any webpage",
    "manifest_version": 3,
    "permissions": [
        "activeTab",
        "scripting",
        "contextMenus",
        "storage"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "frontend/popup.html",
        "default_icon": "public/logo.png"
    },
    "icons": {
        "48": "public/logo.png",
        "128": "public/logo.png"
    }
}

{
    "name": "Slopify",
    "version": "1.0",
    "description": "Fact-check highlighted text on any webpage",
    "manifest_version": 3,
    "permissions": [
        "activeTab",
        "scripting",
        "contextMenus",
        "storage"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "frontend/popup/popup.html",
        "default_icon": "public/Slopify.png"
    },
    "options_ui": {
        "page": "frontend/options/options.html",
        "open_in_tab": false
    },
    "icons": {
        "48": "public/Slopify.png",
        "128": "public/Slopify.png"
    }
}

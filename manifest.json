{
    "name": "Slopify",
    "version": "1.0",
    "description": "Detect AI Slop on any website",
    "manifest_version": 3,
    "action": {
        "default_popup": "frontend/popup/popup.html",
        "default_icon": "public/Slopify.png"
    },
    "options_page": "frontend/options/options.html",
    "permissions": [
        "contextMenus",
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "background": {
        "service_worker": "service-worker.js"
    }
}
